<script setup>
import { ref, onMounted, computed } from 'vue';
import axios from 'axios';
import { useRouter } from 'vue-router';

const router = useRouter();
const user = ref({ hp: 100, xp: 0, level: 1, coins: 0, name: '' });
const habits = ref([]);
const newHabit = ref({ title: '', type: 'Diaria', difficulty: 'Fácil' });

onMounted(async () => {
  const storedUser = localStorage.getItem('user');
  if (!storedUser) {
    router.push('/login');
    return;
  }
  user.value = JSON.parse(storedUser);
  await fetchHabits();
});

const xpNeeded = computed(() => (user.value.level || 1) * 100);
const xpPercentage = computed(() => (user.value.xp / xpNeeded.value) * 100);

// SISTEMA DE TIERS (Evolución Visual Detallada)
const characterTier = computed(() => {
  const lvl = user.value.level || 1;
  const colorArmor = lvl < 5 ? '#333' : (lvl < 10 ? '#78909c' : '#f1c40f');
  
  return {
    name: lvl < 5 ? 'Latente' : (lvl < 10 ? 'Superviviente' : 'Señor de la Ceniza'),
    desc: lvl < 5 ? 'Un alma desnuda frente al destino.' : 'Forjado en la disciplina.',
    // ESTE ES EL NUEVO SVG DETALLADO
    svg: `
      <svg viewBox="0 0 100 120" class="hero-svg">
        <defs>
          <filter id="shadow"><feDropShadow dx="0" dy="2" stdDeviation="3" flood-opacity="0.5"/></filter>
          <linearGradient id="armorGrad" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" style="stop-color:${colorArmor};stop-opacity:1" />
            <stop offset="100%" style="stop-color:#111;stop-opacity:1" />
          </linearGradient>
        </defs>
        
        <path d="M40 35 L60 35 L65 50 L35 50 Z" fill="${colorArmor}" stroke="#000" stroke-width="0.5" filter="url(#shadow)"/> <path d="M35 50 L65 50 L60 90 L40 90 Z" fill="url(#armorGrad)" stroke="#000" stroke-width="0.5"/> <path d="M38 90 L62 90 L60 110 L40 110 Z" fill="#222"/> <circle cx="35" cy="48" r="7" fill="${colorArmor}" stroke="#000" stroke-width="0.5" />
        <circle cx="65" cy="48" r="7" fill="${colorArmor}" stroke="#000" stroke-width="0.5" />

        <path d="M42 22 Q50 12 58 22 L60 42 L40 42 Z" fill="${colorArmor}" stroke="#000" />
        <rect x="44" y="28" width="12" height="3" fill="#111" /> <rect x="30" y="52" width="6" height="30" rx="3" fill="#222" />
        <rect x="64" y="52" width="6" height="30" rx="3" fill="#222" />
        <rect x="42" y="95" width="6" height="20" rx="2" fill="#222" />
        <rect x="52" y="95" width="6" height="20" rx="2" fill="#222" />

        ${lvl >= 5 ? `
          <g transform="translate(72, 45) rotate(15)">
            <rect x="0" y="0" width="3" height="40" fill="#ddd" stroke="#000" /> <rect x="-4" y="30" width="11" height="2" fill="#5d4037" /> <rect x="0" y="32" width="3" height="10" fill="#3e2723" /> </g>
        ` : ''}

        ${lvl >= 10 ? `
          <path d="M35 38 L25 110 L75 110 L65 38 Z" fill="#7b0000" opacity="0.8" z-index="-1"/>
        ` : ''}
      </svg>`
  };
});

const fetchHabits = async () => {
  try {
    const response = await axios.get(`http://localhost:3000/api/habits/user/${user.value.id}`);
    habits.value = response.data;
  } catch (error) { console.error(error); }
};

const createHabit = async () => {
  try {
    await axios.post('http://localhost:3000/api/habits', { ...newHabit.value, user_id: user.value.id });
    newHabit.value.title = '';
    await fetchHabits();
  } catch (error) { alert('Error al crear la misión.'); }
};

const completeHabit = async (habitId) => {
  try {
    const response = await axios.put(`http://localhost:3000/api/habits/${habitId}/complete`, { userId: user.value.id });
    user.value = { ...user.value, ...response.data.stats };
    localStorage.setItem('user', JSON.stringify(user.value));
    await fetchHabits();
  } catch (error) { alert('Error al completar la misión'); }
};

const failHabit = async (habitId) => {
  try {
    const response = await axios.put(`http://localhost:3000/api/habits/${habitId}/fail`, { userId: user.value.id });
    user.value = { ...user.value, ...response.data.stats };
    localStorage.setItem('user', JSON.stringify(user.value));
    await fetchHabits();
  } catch (error) { alert('Error al procesar el daño'); }
};

const deleteHabit = async (habitId) => {
  if (!confirm('¿Abandonar misión?')) return;
  try {
    await axios.delete(`http://localhost:3000/api/habits/${habitId}`);
    await fetchHabits();
  } catch (error) { alert('Error al abandonar la misión'); }
};

const buyReward = (cost) => {
  if (user.value.coins < cost) return alert("¡Te falta oro!");
  user.value.coins -= cost;
  localStorage.setItem('user', JSON.stringify(user.value));
  alert("💰 Compra realizada.");
};

const logout = () => {
  localStorage.removeItem('user');
  router.push('/login');
};
</script>

